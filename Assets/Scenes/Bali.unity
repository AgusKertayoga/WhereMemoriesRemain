    - target: {fileID: 8557568673631317014, guid: a0dbeffc84669e24f994d387893a803d, type: 3}
      propertyPath: sentences.Array.data[0].sentence
      value: 'Selamat datang. Dari wajahmu, sepertinya ini pertama kali kamu datang
        ke festival ini. '
      objectReference: {fileID: 0}
    - target: {fileID: 8557568673631317014, guid: a0dbeffc84669e24f994d387893a803d, type: 3}
      propertyPath: sentences.Array.data[1].sentence
      value: 'Sebenarnya saya juga tidak yakin. Saya kehilangan ingatan dan sedang
        mencari petunjuk tentang masa lalu saya. '
      objectReference: {fileID: 0}
    - target: {fileID: 8557568673631317014, guid: a0dbeffc84669e24f994d387893a803d, type: 3}
      propertyPath: sentences.Array.data[2].sentence
      value: 'Tidak apa-apa. Kadang tempat seperti ini bisa membangkitkan kenangan
        yang sudah lama terlupakan. '
      objectReference: {fileID: 0}
